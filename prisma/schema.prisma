generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  business   String?
  message    String
  package    String?
  createdAt  DateTime @default(now())
}